# Copy to .env.local and fill in values.
# Required for basic app + auth
DATABASE_URL=postgres://user:password@host:5432/dbname
BETTER_AUTH_SECRET=generate-a-secure-random-string
HC_IDENTITY_HOST=https://hca.dinosaurbbq.org
HC_IDENTITY_CLIENT_ID=
HC_IDENTITY_CLIENT_SECRET=
HC_IDENTITY_REDIRECT_URI=http://localhost:3000/api/auth/callback/hackclub-identity
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.com
# Optional
# R2_ENDPOINT=
# R2_REGION=auto

# Integrations (optional; features degrade gracefully without them)
# SLACK_BOT_TOKEN=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_GRANTS_TABLE=
# HACKATIME_API_TOKEN=
# HACKATIME_RACK_ATTACK_BYPASS_TOKEN=
# LOOPS_API_KEY=
# LOOPS_TRANSACTIONAL_REVIEW_EMAIL_ID=

# Optional: Hackatime Billy review tool URL (default: https://billy.3kh0.net)
# NEXT_PUBLIC_HACKATIME_BILLY_URL=
